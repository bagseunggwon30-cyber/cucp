# CUCP runtime / cache (런타임에 만들어지는 파일들 — push 안 함)
# 이 폴더들은 macro cleanup / wrapper 동작 중 자동 생성/삭제
*.log
*.ndjson
wrapper-cache/
appshot-*.json
appshot-*.png
screenshots/
trajectory.ndjson
smart-click-history.ndjson

# OS / 에디터 로컬 메타
.DS_Store
Thumbs.db
*.swp
*.swo
*~

# Python venv (만약 references/scripts 안에 들어올 경우)
__pycache__/
*.pyc
.venv/
venv/

# Node modules (스킬 자체엔 없지만 future-proof)
node_modules/

# 잠재적 secret 위치 (현재 없지만 향후 보호)
.env
.env.local
*.key
*.pem
secrets/
credentials/

# Build/test temp
*.tmp
*.bak

# v1.4.0: 임시 디버그 / 테스트 헬퍼 (절대 commit 안 함)
tests/_*.ps1
tests/scratch-*.ps1
*.pester-out

# v2.1.x: agent temp diagnostic scripts (dot prefix) + pester output cache (do not commit)
tests/.*.ps1
tests/.*.txt

# live-verify cassettes: 로컬 환경에서 실행한 결과 (창 제목 / URL 등 개인 화면 정보
# 포함 가능). 공개 배포물에 넣지 않는다. 필요하면 references/live-cassette-runner.ps1 로 재생성.
live-verify/
